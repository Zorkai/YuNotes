# ─── Build outputs ───────────────────────────────────────────────────────────
bin/
obj/
[Bb]uild/
*.binlog
*.cache

# ─── Visual Studio / IDEs ────────────────────────────────────────────────────
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
# VS Code
.vscode/
# Rider
.idea/

# ─── NuGet ───────────────────────────────────────────────────────────────────
*.nupkg
*.snupkg
packages/
.nuget/

# ─── MSIX / packaging artifacts ──────────────────────────────────────────────
# Built packages and packaging output. NOTE: do NOT ignore Package.appxmanifest
# (it's source) — that's why these are specific extensions, not *.appx*.
packaging/output/
packaging/release/
*.msix
*.msixbundle
*.msixupload
*.msixsym
*.appx
*.appxbundle
*.appxupload
*.appxsym
*.appxrecipe
AppPackages/
BundleArtifacts/
GeneratedArtifacts/
_pkginfo.txt

# ─── Secrets — signing certificates & keys (NEVER commit) ────────────────────
# The dev signing cert is regenerated by packaging/build.ps1, so it never needs
# to be in source control. The .pfx contains a private key.
*.pfx
*.p12
*.snk
*.cer
*.pvk

# ─── Claude ──────────────────────────────────────────────────────────────────
.claude/

# ─── Windows / OS ────────────────────────────────────────────────────────────
Thumbs.db
Desktop.ini
ehthumbs.db
*.lnk
.DS_Store

# ─── Logs ────────────────────────────────────────────────────────────────────
*.log
