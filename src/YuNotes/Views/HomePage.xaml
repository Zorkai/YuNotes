<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YuNotes.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             Sidebar
        ══════════════════════════════════════════════════════════════ -->
        <Border x:Name="SidebarBorder"
                Grid.Column="0"
                Width="260"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Navigation items -->
                <StackPanel Grid.Row="0" Padding="8,8,8,4" Spacing="2">

                    <Button x:Name="AllNotesNavBtn"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,9">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon x:Name="AllNotesIcon" Glyph="&#xe26c;" FontSize="14" Foreground="White" />
                            <TextBlock x:Name="AllNotesLabel" Text="All notes"
                                       VerticalAlignment="Center" FontSize="13" Foreground="White" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="TrashNavBtn"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,9">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xe872;" FontSize="14"
                                      Foreground="White" />
                            <TextBlock Text="Trash" VerticalAlignment="Center" FontSize="13"
                                       Foreground="White" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ArchiveNavBtn"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,9">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xe149;" FontSize="14"
                                      FontFamily="{StaticResource MaterialIconsFamily}"
                                      Foreground="White" />
                            <TextBlock Text="Archive" VerticalAlignment="Center" FontSize="13"
                                       Foreground="White" />
                        </StackPanel>
                    </Button>

                    <!-- Dashed section divider -->
                    <Line X1="0" X2="1" Stretch="Fill"
                          Stroke="{ThemeResource AppBorderBrush}"
                          StrokeThickness="1"
                          StrokeDashArray="3,3"
                          Margin="4,8,4,8" Opacity="0.6" />

                </StackPanel>

                <!-- Folder section — always visible -->
                <Grid x:Name="FolderSection" Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button x:Name="NewFolderBtn"
                            Grid.Row="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,8,10,8"
                            Margin="8,4,8,2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE2CC;" FontSize="14"
                                      FontFamily="{StaticResource MaterialIconsFamily}"
                                      Foreground="White" />
                            <TextBlock Text="New folder" FontSize="13"
                                       Foreground="White"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Separator between New folder and the folder list -->
                    <Line Grid.Row="1" X1="0" X2="1" Stretch="Fill"
                          Stroke="{ThemeResource AppBorderBrush}"
                          StrokeThickness="1"
                          StrokeDashArray="3,3"
                          Margin="8,2,8,6" Opacity="0.6" />

                    <TreeView x:Name="FolderTree"
                              Grid.Row="2"
                              SelectionMode="Single"
                              Padding="4,2,4,8"
                              AllowDrop="True">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="MinHeight" Value="34" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,2,4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                                                Margin="-26,0,0,0">
                                        <FontIcon Glyph="{Binding Content.Glyph}" FontSize="14"
                                                  FontFamily="{StaticResource MaterialIconsFamily}"
                                                  Foreground="White" />
                                        <TextBlock Text="{Binding Content.Name}"
                                                   FontSize="13"
                                                   Foreground="White"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Click="FolderMoreBtn_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="6,2"
                                            CornerRadius="6"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Folder options">
                                        <FontIcon Glyph="&#xE5D3;" FontSize="14"
                                                  FontFamily="{StaticResource MaterialIconsFamily}"
                                                  Foreground="White" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>

                <!-- Bottom: Settings + warning indicator -->
                <Border Grid.Row="2"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6,8,12">
                    <Grid>
                        <Button x:Name="SettingsBtn"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="8"
                                Padding="10,9">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xe8b8;" FontSize="14"
                                          Foreground="White" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="13"
                                           Foreground="White" />
                            </StackPanel>
                        </Button>
                        <FontIcon x:Name="WarningIcon"
                                  Glyph="&#xe002;"
                                  FontSize="14"
                                  Foreground="#E8A428"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  Visibility="Collapsed" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             Main content
        ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar: hamburger + title left, actions right -->
            <Border Grid.Row="0"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="4,0,12,0"
                    MinHeight="52">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: sidebar toggle + section title -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button x:Name="SidebarToggleBtn"
                                Style="{StaticResource ToolButtonStyle}"
                                ToolTipService.ToolTip="Toggle sidebar">
                            <FontIcon Glyph="&#xe5d2;" />
                        </Button>
                        <TextBlock x:Name="SectionTitle" Text="All notes"
                                   Style="{StaticResource H2Style}"
                                   VerticalAlignment="Center" />
                    </StackPanel>

                    <!-- Normal mode -->
                    <StackPanel x:Name="HeaderNormal"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="4">
                        <Button x:Name="NewBtn"
                                Padding="12,7" CornerRadius="8"
                                Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xe89c;" FontSize="14" />
                                <TextBlock Text="Create note" VerticalAlignment="Center" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="OpenBtn"
                                Padding="12,7" CornerRadius="8"
                                Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xe415;" FontSize="14" />
                                <TextBlock Text="Import PDF" VerticalAlignment="Center" FontSize="13" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SelectBtn"
                                Style="{StaticResource ToolButtonStyle}"
                                ToolTipService.ToolTip="Select notes">
                            <FontIcon Glyph="&#xe162;" />
                        </Button>
                    </StackPanel>

                    <!-- Select mode -->
                    <StackPanel x:Name="HeaderSelect"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8"
                                Visibility="Collapsed">
                        <TextBlock x:Name="SelectionCountLabel" Text="0 selected"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Style="{StaticResource MutedStyle}" />
                        <Button x:Name="RestoreBtn"
                                Padding="12,7" CornerRadius="8"
                                Background="Transparent" BorderThickness="0"
                                IsEnabled="False" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE777;" FontSize="14" />
                                <TextBlock Text="Restore" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="UnarchiveBtn"
                                Padding="12,7" CornerRadius="8"
                                Background="Transparent" BorderThickness="0"
                                IsEnabled="False" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xe169;" FontSize="14"
                                          FontFamily="{StaticResource MaterialIconsFamily}" />
                                <TextBlock Text="Unarchive" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="MoveToFolderBtn"
                                Padding="12,7" CornerRadius="8"
                                Background="Transparent" BorderThickness="0" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xe2c8;" FontSize="14" />
                                <TextBlock Text="Move to" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ArchiveBtn"
                                Padding="12,7" CornerRadius="8"
                                Background="Transparent" BorderThickness="0" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xe149;" FontSize="14"
                                          FontFamily="{StaticResource MaterialIconsFamily}" />
                                <TextBlock Text="Archive" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DeleteBtn"
                                Padding="12,7" CornerRadius="8"
                                Background="#E03A3A" Foreground="White"
                                BorderThickness="0" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xe872;" FontSize="14" />
                                <TextBlock x:Name="DeleteBtnLabel" Text="Move to Trash" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CancelSelectBtn"
                                Padding="12,7" CornerRadius="8">
                            <TextBlock Text="Cancel" />
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- Notes area -->
            <Grid Grid.Row="1">

                <!-- Empty state (hidden when notes exist) -->
                <StackPanel x:Name="EmptyHint"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="6"
                            Visibility="Collapsed">
                    <TextBlock x:Name="EmptyHintTitle" Text="No notes"
                               HorizontalAlignment="Center"
                               FontSize="16"
                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                    <TextBlock x:Name="EmptyHintSubtitle" Text="Tap Create note to add one."
                               HorizontalAlignment="Center"
                               FontSize="13"
                               Foreground="{ThemeResource AppTextSecondaryBrush}"
                               Opacity="0.55" />
                </StackPanel>

                <!-- Notes grid -->
                <ScrollViewer Padding="20,16,20,24">
                    <GridView x:Name="RecentList"
                              SelectionMode="None"
                              IsItemClickEnabled="True"
                              CanDragItems="True"
                              IsMultiSelectCheckBoxEnabled="False"
                              ItemClick="RecentList_ItemClick">
                        <GridView.ItemContainerStyle>
                            <Style TargetType="GridViewItem">
                                <Setter Property="Margin" Value="0,0,12,12" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                <Setter Property="UseSystemFocusVisuals" Value="False" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="GridViewItem">
                                            <Grid CornerRadius="14">
                                                <VisualStateManager.VisualStateGroups>
                                                    <VisualStateGroup x:Name="CommonStates">
                                                        <VisualState x:Name="Normal" />
                                                        <VisualState x:Name="PointerOver">
                                                            <VisualState.Setters>
                                                                <Setter Target="HoverBorder.Opacity" Value="1" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="Pressed">
                                                            <VisualState.Setters>
                                                                <Setter Target="HoverBorder.Opacity" Value="1" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="Selected">
                                                            <VisualState.Setters>
                                                                <Setter Target="SelTint.Opacity" Value="0.22" />
                                                                <Setter Target="SelBorder.Opacity" Value="1" />
                                                                <Setter Target="CheckBadge.Opacity" Value="1" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="PointerOverSelected">
                                                            <VisualState.Setters>
                                                                <Setter Target="SelTint.Opacity" Value="0.22" />
                                                                <Setter Target="SelBorder.Opacity" Value="1" />
                                                                <Setter Target="CheckBadge.Opacity" Value="1" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="PressedSelected">
                                                            <VisualState.Setters>
                                                                <Setter Target="SelTint.Opacity" Value="0.22" />
                                                                <Setter Target="SelBorder.Opacity" Value="1" />
                                                                <Setter Target="CheckBadge.Opacity" Value="1" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                        <VisualState x:Name="SelectedUnfocused">
                                                            <VisualState.Setters>
                                                                <Setter Target="SelTint.Opacity" Value="0.22" />
                                                                <Setter Target="SelBorder.Opacity" Value="1" />
                                                                <Setter Target="CheckBadge.Opacity" Value="1" />
                                                            </VisualState.Setters>
                                                        </VisualState>
                                                    </VisualStateGroup>
                                                </VisualStateManager.VisualStateGroups>

                                                <!-- The note card itself -->
                                                <ContentPresenter
                                                    Content="{TemplateBinding Content}"
                                                    ContentTemplate="{TemplateBinding ContentTemplate}"
                                                    HorizontalAlignment="Stretch"
                                                    VerticalAlignment="Stretch" />

                                                <!-- Subtle hover hint -->
                                                <Border x:Name="HoverBorder"
                                                        CornerRadius="14"
                                                        BorderThickness="1"
                                                        BorderBrush="{ThemeResource AppAccentBrush}"
                                                        Opacity="0"
                                                        IsHitTestVisible="False" />

                                                <!-- Selection tint + accent border -->
                                                <Border x:Name="SelTint"
                                                        CornerRadius="14"
                                                        Background="{ThemeResource AppAccentSoftBrush}"
                                                        Opacity="0"
                                                        IsHitTestVisible="False" />
                                                <Border x:Name="SelBorder"
                                                        CornerRadius="14"
                                                        BorderThickness="2.5"
                                                        BorderBrush="{ThemeResource AppAccentBrush}"
                                                        Opacity="0"
                                                        IsHitTestVisible="False" />

                                                <!-- Check badge, top-right -->
                                                <Border x:Name="CheckBadge"
                                                        Width="28" Height="28"
                                                        CornerRadius="14"
                                                        Background="{ThemeResource AppAccentBrush}"
                                                        BorderBrush="{ThemeResource AppSurfaceBrush}"
                                                        BorderThickness="2"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Top"
                                                        Margin="0,8,8,0"
                                                        Opacity="0"
                                                        IsHitTestVisible="False">
                                                    <FontIcon Glyph="&#xE5CA;"
                                                              FontSize="16"
                                                              FontFamily="{StaticResource MaterialIconsFamily}"
                                                              Foreground="White" />
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </GridView.ItemContainerStyle>
                        <GridView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{ThemeResource AppSurfaceBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14"
                                        Padding="12"
                                        Width="220" Height="220">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Border Grid.Row="0" CornerRadius="8"
                                                Background="{ThemeResource AppSurfaceVariantBrush}"
                                                HorizontalAlignment="Stretch"
                                                VerticalAlignment="Stretch">
                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" />
                                        </Border>
                                        <StackPanel Grid.Row="1" Margin="0,10,0,0" Spacing="2">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding Subtitle}"
                                                       Style="{StaticResource MutedStyle}"
                                                       TextTrimming="CharacterEllipsis" />
                                            <StackPanel Orientation="Horizontal" Spacing="4"
                                                        Visibility="{Binding FolderLabelVisibility}"
                                                        Margin="0,1,0,0">
                                                <TextBlock Text="&#xE2C8;"
                                                           FontFamily="{StaticResource MaterialIconsFamily}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                                                           VerticalAlignment="Center" Opacity="0.6"/>
                                                <TextBlock Text="{Binding FolderName}"
                                                           FontSize="11"
                                                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Opacity="0.6" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </GridView.ItemTemplate>
                    </GridView>
                </ScrollViewer>

            </Grid>
        </Grid>
    </Grid>
</Page>
