<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YuNotes.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             Sidebar
        ══════════════════════════════════════════════════════════════ -->
        <!-- Transparent over the window Mica (Windows 11 style) — an opaque
             surface here reads as a flat gray slab against the backdrop. -->
        <Border x:Name="SidebarBorder"
                Grid.Column="0"
                Width="260"
                Background="Transparent"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Navigation items -->
                <StackPanel Grid.Row="0" Padding="8,8,8,4" Spacing="2">
                    <StackPanel.ChildrenTransitions>
                        <TransitionCollection>
                            <EntranceThemeTransition IsStaggeringEnabled="True" />
                        </TransitionCollection>
                    </StackPanel.ChildrenTransitions>

                    <Button x:Name="AllNotesNavBtn"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon x:Name="AllNotesIcon" Glyph="&#xe26c;" FontSize="18" Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <TextBlock x:Name="AllNotesLabel" Text="All notes"
                                       VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource AppTextPrimaryBrush}" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="TrashNavBtn"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xe872;" FontSize="18"
                                      Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <TextBlock Text="Trash" VerticalAlignment="Center" FontSize="14"
                                       Foreground="{ThemeResource AppTextPrimaryBrush}" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="ArchiveNavBtn"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xe149;" FontSize="18"
                                      FontFamily="{StaticResource MaterialIconsFamily}"
                                      Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <TextBlock Text="Archive" VerticalAlignment="Center" FontSize="14"
                                       Foreground="{ThemeResource AppTextPrimaryBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- Dashed section divider -->
                    <Line X1="0" X2="1" Stretch="Fill"
                          Stroke="{ThemeResource AppBorderBrush}"
                          StrokeThickness="1"
                          StrokeDashArray="3,3"
                          Margin="4,8,4,8" Opacity="0.6" />

                </StackPanel>

                <!-- Folder section — always visible -->
                <Grid x:Name="FolderSection" Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Button x:Name="NewFolderBtn"
                            Grid.Row="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Left"
                            Background="Transparent"
                            BorderThickness="0"
                            CornerRadius="8"
                            Padding="10,10,10,10"
                            Margin="8,4,8,2">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE2CC;" FontSize="18"
                                      FontFamily="{StaticResource MaterialIconsFamily}"
                                      Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <TextBlock Text="New folder" FontSize="14"
                                       Foreground="{ThemeResource AppTextPrimaryBrush}"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>

                    <!-- Separator between New folder and the folder list -->
                    <Line Grid.Row="1" X1="0" X2="1" Stretch="Fill"
                          Stroke="{ThemeResource AppBorderBrush}"
                          StrokeThickness="1"
                          StrokeDashArray="3,3"
                          Margin="8,2,8,6" Opacity="0.6" />

                    <TreeView x:Name="FolderTree"
                              Grid.Row="2"
                              SelectionMode="Single"
                              Padding="4,2,4,8"
                              AllowDrop="True">
                        <TreeView.ItemContainerStyle>
                            <Style TargetType="TreeViewItem">
                                <Setter Property="MinHeight" Value="40" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </TreeView.ItemContainerStyle>
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <Grid Padding="0,2,4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10"
                                                Margin="-26,0,0,0">
                                        <FontIcon Glyph="{Binding Content.Glyph}" FontSize="18"
                                                  FontFamily="{StaticResource MaterialIconsFamily}"
                                                  Foreground="{ThemeResource AppTextPrimaryBrush}" />
                                        <TextBlock Text="{Binding Content.Name}"
                                                   FontSize="14"
                                                   Foreground="{ThemeResource AppTextPrimaryBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Grid.Column="1"
                                            Click="FolderMoreBtn_Click"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="6,2"
                                            CornerRadius="6"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Folder options">
                                        <FontIcon Glyph="&#xE5D3;" FontSize="18"
                                                  FontFamily="{StaticResource MaterialIconsFamily}"
                                                  Foreground="{ThemeResource AppTextPrimaryBrush}" />
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Grid>

                <!-- Bottom: Settings + warning indicator -->
                <Border Grid.Row="2"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="8,6,8,12">
                    <Grid>
                        <Button x:Name="SettingsBtn"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                CornerRadius="8"
                                Padding="10,10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xe8b8;" FontSize="18"
                                          Foreground="{ThemeResource AppTextPrimaryBrush}" />
                                <TextBlock Text="Settings" VerticalAlignment="Center" FontSize="14"
                                           Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            </StackPanel>
                        </Button>
                        <FontIcon x:Name="WarningIcon"
                                  Glyph="&#xe002;"
                                  FontSize="14"
                                  Foreground="#E8A428"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Center"
                                  Margin="0,0,12,0"
                                  Visibility="Collapsed" />
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             Main content
        ══════════════════════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Top bar: hamburger left, actions right -->
            <Border x:Name="HeaderBar" Grid.Row="0"
                    BorderBrush="{ThemeResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="4,0,12,0"
                    MinHeight="48">
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Window drag region. SetTitleBar turns this element's bounds
                         into non-client space (controls overlapping it lose input),
                         so it only covers the empty middle column. -->
                    <Border x:Name="HeaderDragRegion" Grid.Column="1"
                            Background="Transparent" Margin="0,-8" />

                    <!-- Left: sidebar toggle -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button x:Name="SidebarToggleBtn"
                                Style="{StaticResource ToolButtonStyle}"
                                ToolTipService.ToolTip="Toggle sidebar">
                            <FontIcon Glyph="&#xe5d2;" />
                        </Button>
                    </StackPanel>

                    <!-- Normal mode -->
                    <StackPanel x:Name="HeaderNormal"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="4">
                        <Button x:Name="NewBtn"
                                Padding="12,8" CornerRadius="8"
                                Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xe89c;" FontSize="18" />
                                <TextBlock Text="Create note" VerticalAlignment="Center" FontSize="14" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="OpenBtn"
                                Padding="12,8" CornerRadius="8"
                                Background="Transparent" BorderThickness="0">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xe415;" FontSize="18" />
                                <TextBlock Text="Import PDF" VerticalAlignment="Center" FontSize="14" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="SelectBtn"
                                Style="{StaticResource ToolButtonStyle}"
                                ToolTipService.ToolTip="Select notes">
                            <FontIcon Glyph="&#xe162;" />
                        </Button>
                    </StackPanel>

                    <!-- Select mode -->
                    <StackPanel x:Name="HeaderSelect"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="8"
                                Visibility="Collapsed">
                        <TextBlock x:Name="SelectionCountLabel" Text="0 selected"
                                   VerticalAlignment="Center" Margin="0,0,8,0"
                                   Style="{StaticResource MutedStyle}" />
                        <Button x:Name="RestoreBtn"
                                Padding="12,8" CornerRadius="8"
                                Background="Transparent" BorderThickness="0"
                                IsEnabled="False" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE777;" FontSize="18" />
                                <TextBlock Text="Restore" VerticalAlignment="Center" FontSize="14" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="UnarchiveBtn"
                                Padding="12,8" CornerRadius="8"
                                Background="Transparent" BorderThickness="0"
                                IsEnabled="False" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xe169;" FontSize="18"
                                          FontFamily="{StaticResource MaterialIconsFamily}" />
                                <TextBlock Text="Unarchive" VerticalAlignment="Center" FontSize="14" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="MoveToFolderBtn"
                                Padding="12,8" CornerRadius="8"
                                Background="Transparent" BorderThickness="0" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xe2c8;" FontSize="18" />
                                <TextBlock Text="Move to" VerticalAlignment="Center" FontSize="14" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="ArchiveBtn"
                                Padding="12,8" CornerRadius="8"
                                Background="Transparent" BorderThickness="0" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xe149;" FontSize="18"
                                          FontFamily="{StaticResource MaterialIconsFamily}" />
                                <TextBlock Text="Archive" VerticalAlignment="Center" FontSize="14" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DeleteBtn"
                                Padding="12,8" CornerRadius="8"
                                Background="#E03A3A" Foreground="White"
                                BorderThickness="0" IsEnabled="False">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xe872;" FontSize="18" />
                                <TextBlock x:Name="DeleteBtnLabel" Text="Move to Trash" VerticalAlignment="Center" FontSize="14" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="CancelSelectBtn"
                                Padding="12,8" CornerRadius="8">
                            <TextBlock Text="Cancel" FontSize="14" />
                        </Button>
                    </StackPanel>

                </Grid>
            </Border>

            <!-- Notes area -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Section header: title + sort bar -->
                <Grid Grid.Row="0" Padding="24,18,24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock x:Name="SectionTitle" Text="All notes"
                               Style="{StaticResource H1Style}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="{ThemeResource AppSurfaceVariantBrush}"
                                CornerRadius="8" Padding="2">
                            <StackPanel Orientation="Horizontal" Spacing="1">
                                <Button x:Name="SortByDateBtn"
                                        Content="Date" FontSize="13"
                                        Padding="12,6" CornerRadius="6"
                                        Background="{ThemeResource AppSurfaceBrush}"
                                        BorderThickness="0" />
                                <Button x:Name="SortByNameBtn"
                                        Content="Name" FontSize="13"
                                        Padding="12,6" CornerRadius="6"
                                        Background="Transparent"
                                        BorderThickness="0" />
                                <Button x:Name="SortByTypeBtn"
                                        Content="Type" FontSize="13"
                                        Padding="12,6" CornerRadius="6"
                                        Background="Transparent"
                                        BorderThickness="0" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- Content: empty hint + notes grid -->
                <Grid Grid.Row="1">

                    <!-- Empty state (hidden when notes exist) -->
                    <StackPanel x:Name="EmptyHint"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="6"
                                Visibility="Collapsed">
                        <TextBlock x:Name="EmptyHintTitle" Text="No notes"
                                   HorizontalAlignment="Center"
                                   FontSize="16"
                                   Foreground="{ThemeResource AppTextSecondaryBrush}" />
                        <TextBlock x:Name="EmptyHintSubtitle" Text="Tap Create note to add one."
                                   HorizontalAlignment="Center"
                                   FontSize="13"
                                   Foreground="{ThemeResource AppTextSecondaryBrush}"
                                   Opacity="0.55" />
                    </StackPanel>

                    <!-- Notes grid -->
                    <ScrollViewer Padding="24,12,24,24">
                        <GridView x:Name="RecentList"
                                  SelectionMode="None"
                                  IsItemClickEnabled="True"
                                  CanDragItems="True"
                                  IsMultiSelectCheckBoxEnabled="False"
                                  ItemContainerStyle="{StaticResource NoteCardContainerStyle}"
                                  ItemClick="RecentList_ItemClick">
                            <GridView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <EntranceThemeTransition IsStaggeringEnabled="True" />
                                </TransitionCollection>
                            </GridView.ItemContainerTransitions>
                            <GridView.ItemTemplate>
                                <DataTemplate>
                                    <!-- Transparent (not null) background: the "New..." card's
                                         dashed rectangle has no fill, so without this the card
                                         interior is a hit-test hole and hover only fires on the
                                         icon/text. -->
                                    <Grid Width="165" Height="215" Background="Transparent">

                                        <!-- Regular note card -->
                                        <Border Background="{ThemeResource AppSurfaceBrush}"
                                                BorderBrush="{ThemeResource AppBorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="14"
                                                Visibility="{Binding NormalCardVisibility}"
                                                PointerEntered="Card_PointerEntered"
                                                PointerExited="Card_PointerExited">
                                            <Border.Shadow>
                                                <ThemeShadow />
                                            </Border.Shadow>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="*" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0"
                                                        CornerRadius="13,13,0,0"
                                                        Background="{ThemeResource AppSurfaceVariantBrush}">
                                                    <Image x:Name="CardThumb"
                                                           Source="{Binding Thumbnail}"
                                                           Stretch="Uniform" />
                                                </Border>
                                                <StackPanel Grid.Row="1"
                                                            Padding="10,8,10,10"
                                                            Spacing="2">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               FontSize="13"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextAlignment="Center" />
                                                    <TextBlock Text="{Binding Subtitle}"
                                                               FontSize="11"
                                                               Style="{StaticResource MutedStyle}"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextAlignment="Center" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <!-- "New..." card -->
                                        <Grid Visibility="{Binding NewCardVisibility}">
                                            <Rectangle Stroke="{ThemeResource AppBorderBrush}"
                                                       StrokeThickness="1.5"
                                                       StrokeDashArray="4,3"
                                                       RadiusX="14" RadiusY="14"
                                                       Opacity="0.5" />
                                            <StackPanel VerticalAlignment="Center"
                                                        HorizontalAlignment="Center"
                                                        Spacing="10">
                                                <FontIcon Glyph="&#xe145;"
                                                          FontSize="28"
                                                          HorizontalAlignment="Center"
                                                          Foreground="{ThemeResource AppTextSecondaryBrush}"
                                                          Opacity="0.6" />
                                                <TextBlock Text="New..."
                                                           FontSize="13"
                                                           Foreground="{ThemeResource AppTextSecondaryBrush}"
                                                           Opacity="0.7"
                                                           HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>

                                    </Grid>
                                </DataTemplate>
                            </GridView.ItemTemplate>
                        </GridView>
                    </ScrollViewer>

                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
