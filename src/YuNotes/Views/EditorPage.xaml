<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YuNotes.Views.EditorPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="using:YuNotes.Controls"
    xmlns:canvas="using:Microsoft.Graphics.Canvas.UI.Xaml"
    KeyboardAcceleratorPlacementMode="Hidden"
    Background="{ThemeResource AppBackgroundBrush}">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition x:Name="RowTop" Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition x:Name="RowBottom" Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="ColLeft" Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition x:Name="ColRight" Width="Auto" />
        </Grid.ColumnDefinitions>

        <!-- Canvas (declared first so the floating toolbar overlays it) -->
        <c:InkCanvasControl x:Name="Canvas" Grid.Row="1" Grid.Column="1" />

        <!-- Ghost-image layer for image placement cursor -->
        <Canvas x:Name="GhostLayer"
                Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="3"
                Canvas.ZIndex="8" IsHitTestVisible="False">
            <Border x:Name="ImageGhost" Opacity="0.72" Visibility="Collapsed"
                    CornerRadius="6" BorderThickness="1.5"
                    BorderBrush="{ThemeResource AppAccentBrush}">
                <Image x:Name="ImageGhostImg" Width="160" Height="120" Stretch="Uniform"/>
            </Border>
        </Canvas>

        <!-- Floating toolbar host — position is set in code. The Border keeps a
             Transparent (hit-testable) background; the inner glass layer paints
             either the acrylic brush or the liquid-glass effect. -->
        <Border x:Name="ToolbarHost"
                Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Canvas.ZIndex="10"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Margin="0,14,0,0"
                CornerRadius="22"
                Background="Transparent"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1"
                Translation="0,0,32">
            <!-- Free-drag offset from the docked anchor. Declared here (not assigned
                 at runtime) so the persisted offset is baked into the first frame,
                 with no post-load reposition flash. -->
            <Border.RenderTransform>
                <TranslateTransform x:Name="ToolbarTranslate" />
            </Border.RenderTransform>
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid>
            <c:LiquidGlassBackdrop x:Name="ToolbarGlass" CornerRadius="22"
                                   Background="{ThemeResource AppToolbarBrush}" />
            <Grid x:Name="ToolbarGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <ScrollViewer x:Name="ToolbarScroller"
                              Grid.Column="0"
                              HorizontalScrollBarVisibility="Hidden"
                              HorizontalScrollMode="Auto"
                              VerticalScrollMode="Disabled"
                              VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="ToolbarPrimary" Orientation="Horizontal" Spacing="6" Padding="12,6"
                                VerticalAlignment="Center" HorizontalAlignment="Left">
                    <Border x:Name="DragHandle"
                            Width="44" Height="44"
                            Background="Transparent"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Drag to move toolbar">
                        <FontIcon x:Name="DragHandleIcon" Glyph="&#xe945;" FontSize="18"
                                  Foreground="{ThemeResource AppTextPrimaryBrush}" />
                    </Border>
                    <Border x:Name="Sep1" Background="{ThemeResource AppBorderBrush}"
                            Width="1" Height="28" Margin="3,0" />
                    <ToggleButton x:Name="ToolHand" Style="{StaticResource ToolToggleButtonStyle}" ToolTipService.ToolTip="Hand (pan)">
                        <FontIcon Glyph="&#xe925;" />
                    </ToggleButton>
                    <Grid x:Name="PenGroup" VerticalAlignment="Center">
                        <ToggleButton x:Name="ToolPen" Style="{StaticResource ToolToggleButtonStyle}"
                                      ToolTipService.ToolTip="Pen" IsChecked="True">
                            <FontIcon x:Name="PenIcon" Glyph="&#xf366;" />
                        </ToggleButton>
                        <Button x:Name="ToolPenChevron" Width="14" Height="14"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,3,-1"
                                Background="Transparent" BorderThickness="0"
                                CornerRadius="3" Padding="0"
                                Style="{StaticResource ToolChevronButtonStyle}"
                                ToolTipService.ToolTip="Pen options">
                            <FontIcon x:Name="PenChevronIcon" Glyph="&#xe5cf;" FontSize="8"
                                      Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <Button.Flyout>
                                <Flyout x:Name="PenFlyout" Placement="Bottom"
                                        ShouldConstrainToRootBounds="True"
                                        FlyoutPresenterStyle="{StaticResource GlassFlyoutPresenterStyle}">
                                    <StackPanel Width="248" Spacing="10">
                                        <TextBlock Text="Pen" Style="{StaticResource FlyoutHeaderStyle}" />
                                        <!-- Live sample stroke rendered with the real stroke
                                             renderer — reflects current color, width and mode. -->
                                        <canvas:CanvasControl x:Name="PenPreview" Height="72"
                                                              Draw="PenPreview_Draw" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton x:Name="PenSolidItem" Grid.Column="0"
                                                          Style="{StaticResource OptionCardStyle}" IsChecked="True"
                                                          ToolTipService.ToolTip="Constant-width stroke">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xf604;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Solid" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton x:Name="PenPressureItem" Grid.Column="1"
                                                          Style="{StaticResource OptionCardStyle}"
                                                          ToolTipService.ToolTip="Width follows pen pressure">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xe3ae;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Pressure" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                        </Grid>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    <ToggleButton x:Name="ToolHighlighter" Style="{StaticResource ToolToggleButtonStyle}" ToolTipService.ToolTip="Highlighter">
                        <FontIcon x:Name="HighlighterIcon" Glyph="&#xf364;" />
                    </ToggleButton>
                    <Grid x:Name="EraserGroup" VerticalAlignment="Center">
                        <ToggleButton x:Name="ToolEraser" Style="{StaticResource ToolToggleButtonStyle}"
                                      ToolTipService.ToolTip="Eraser">
                            <FontIcon x:Name="EraserIcon" Glyph="&#xe6d0;" FontSize="18" />
                        </ToggleButton>
                        <Button x:Name="ToolEraserChevron" Width="14" Height="14"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,3,-1"
                                Background="Transparent" BorderThickness="0"
                                CornerRadius="3" Padding="0"
                                Style="{StaticResource ToolChevronButtonStyle}"
                                ToolTipService.ToolTip="Eraser options">
                            <FontIcon x:Name="EraserChevronIcon" Glyph="&#xe5cf;" FontSize="8"
                                      Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <Button.Flyout>
                                <Flyout x:Name="EraserFlyout" Placement="Bottom"
                                        ShouldConstrainToRootBounds="True"
                                        FlyoutPresenterStyle="{StaticResource GlassFlyoutPresenterStyle}">
                                    <StackPanel Width="220" Spacing="10">
                                        <TextBlock Text="Eraser" Style="{StaticResource FlyoutHeaderStyle}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton x:Name="EraserStrokeItem" Grid.Column="0"
                                                          Style="{StaticResource OptionCardStyle}" IsChecked="True"
                                                          ToolTipService.ToolTip="Erase whole strokes">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xf747;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Stroke" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton x:Name="EraserPixelItem" Grid.Column="1"
                                                          Style="{StaticResource OptionCardStyle}"
                                                          ToolTipService.ToolTip="Erase only what you touch">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xf3fc;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Pixel" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                        </Grid>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    <ToggleButton x:Name="ToolText" Style="{StaticResource ToolToggleButtonStyle}" ToolTipService.ToolTip="Text">
                        <FontIcon Glyph="&#xe262;" />
                    </ToggleButton>
                    <ToggleButton x:Name="ToolImage" Style="{StaticResource ToolToggleButtonStyle}" ToolTipService.ToolTip="Image">
                        <FontIcon Glyph="&#xe3f4;" />
                    </ToggleButton>
                    <!-- Appears only while the clipboard holds an image (Ctrl+V also pastes). -->
                    <Button x:Name="ToolPaste" Style="{StaticResource ToolButtonStyle}"
                            Visibility="Collapsed"
                            ToolTipService.ToolTip="Paste image from clipboard (Ctrl+V)">
                        <FontIcon Glyph="&#xe14f;" FontSize="18" />
                    </Button>
                    <Grid x:Name="ShapeGroup" VerticalAlignment="Center">
                        <ToggleButton x:Name="ToolShape" Style="{StaticResource ToolToggleButtonStyle}"
                                      ToolTipService.ToolTip="Shape">
                            <FontIcon x:Name="ShapeIcon" Glyph="&#xe574;" FontSize="18" />
                        </ToggleButton>
                        <Button x:Name="ToolShapeChevron" Width="14" Height="14"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,3,-1"
                                Background="Transparent" BorderThickness="0"
                                CornerRadius="3" Padding="0"
                                Style="{StaticResource ToolChevronButtonStyle}"
                                ToolTipService.ToolTip="Shape options">
                            <FontIcon x:Name="ShapeChevronIcon" Glyph="&#xe5cf;" FontSize="8"
                                      Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <Button.Flyout>
                                <Flyout x:Name="ShapeFlyout" Placement="Bottom"
                                        ShouldConstrainToRootBounds="True"
                                        FlyoutPresenterStyle="{StaticResource GlassFlyoutPresenterStyle}">
                                    <StackPanel Width="356" Spacing="10">
                                        <TextBlock Text="Shape" Style="{StaticResource FlyoutHeaderStyle}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton x:Name="ShapeRectItem" Grid.Column="0"
                                                          Style="{StaticResource OptionCardStyle}" IsChecked="True">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xeb54;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Rectangle" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton x:Name="ShapeEllipseItem" Grid.Column="1"
                                                          Style="{StaticResource OptionCardStyle}">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xef4a;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Ellipse" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton x:Name="ShapeLineItem" Grid.Column="2"
                                                          Style="{StaticResource OptionCardStyle}">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xf41e;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Line" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton x:Name="ShapeTriangleItem" Grid.Column="3"
                                                          Style="{StaticResource OptionCardStyle}">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xf0a8;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Triangle" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                        </Grid>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    <ToggleButton x:Name="ToolRuler" Style="{StaticResource ToolToggleButtonStyle}"
                                  ToolTipService.ToolTip="Ruler — drag to move, drag tip to rotate; pen snaps to the edge">
                        <FontIcon Glyph="&#xe41c;" FontSize="18" />
                    </ToggleButton>
                    <Grid x:Name="SelectGroup" VerticalAlignment="Center">
                        <ToggleButton x:Name="ToolSelect" Style="{StaticResource ToolToggleButtonStyle}"
                                      ToolTipService.ToolTip="Select">
                            <FontIcon x:Name="SelectIcon" Glyph="&#xeb03;" FontSize="18" />
                        </ToggleButton>
                        <Button x:Name="ToolSelectChevron" Width="14" Height="14"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Margin="0,0,3,-1"
                                Background="Transparent" BorderThickness="0"
                                CornerRadius="3" Padding="0"
                                Style="{StaticResource ToolChevronButtonStyle}"
                                ToolTipService.ToolTip="Select options">
                            <FontIcon x:Name="SelectChevronIcon" Glyph="&#xe5cf;" FontSize="8"
                                      Foreground="{ThemeResource AppTextPrimaryBrush}" />
                            <Button.Flyout>
                                <Flyout x:Name="SelectFlyout" Placement="Bottom"
                                        ShouldConstrainToRootBounds="True"
                                        FlyoutPresenterStyle="{StaticResource GlassFlyoutPresenterStyle}">
                                    <StackPanel Width="220" Spacing="10">
                                        <TextBlock Text="Select" Style="{StaticResource FlyoutHeaderStyle}" />
                                        <Grid ColumnSpacing="8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton x:Name="SelectLassoItem" Grid.Column="0"
                                                          Style="{StaticResource OptionCardStyle}" IsChecked="True"
                                                          ToolTipService.ToolTip="Draw freely around elements">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xeb03;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Lasso" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                            <ToggleButton x:Name="SelectRectItem" Grid.Column="1"
                                                          Style="{StaticResource OptionCardStyle}"
                                                          ToolTipService.ToolTip="Drag a rectangle">
                                                <StackPanel Spacing="6">
                                                    <FontIcon Glyph="&#xe6d4;" FontSize="22" HorizontalAlignment="Center" />
                                                    <TextBlock Text="Rectangle" FontSize="{StaticResource FontSizeCaption}" HorizontalAlignment="Center" />
                                                </StackPanel>
                                            </ToggleButton>
                                        </Grid>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </Grid>
                    <ToggleButton x:Name="ToolExtend"
                                  Style="{StaticResource ToolToggleButtonStyle}"
                                  ToolTipService.ToolTip="Page width — extend a page left or right">
                        <FontIcon Glyph="&#xf72c;" FontSize="18" />
                    </ToggleButton>
                    <Border x:Name="Sep2" Background="{ThemeResource AppBorderBrush}" Width="1" Height="22" Margin="6,0"/>
                    <c:ColorPickerControl x:Name="ColorPicker"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                    <Border x:Name="Sep3" Background="{ThemeResource AppBorderBrush}" Width="1" Height="22" Margin="6,0"/>
                    <c:WidthPickerControl x:Name="WidthPicker" />
                </StackPanel>
                </ScrollViewer>
            </Grid>
            </Grid>
        </Border>

        <!-- Selection action bar — floats over the canvas, decoupled from the
             toolbar so showing it never resizes a docked toolbar. Position
             (top/bottom-centre) is set in ApplyToolbarPosition to avoid the
             toolbar. Plain toolbar brush (no liquid glass — that's toolbar-only). -->
        <Border x:Name="SelectionActions"
                Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Canvas.ZIndex="11"
                HorizontalAlignment="Center" VerticalAlignment="Top"
                Margin="0,14,0,0"
                Visibility="Collapsed"
                CornerRadius="22"
                Padding="6,4"
                Background="{ThemeResource AppToolbarBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1"
                Translation="0,0,32">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel x:Name="SelectionActionsPanel" Orientation="Horizontal" Spacing="4">
                <Button x:Name="SelDuplicateBtn" Style="{StaticResource ToolButtonStyle}" ToolTipService.ToolTip="Duplicate (Ctrl+D)">
                    <FontIcon Glyph="&#xe14d;" />
                </Button>
                <Button x:Name="SelDeleteBtn" Style="{StaticResource ToolButtonStyle}" ToolTipService.ToolTip="Delete (Del)">
                    <FontIcon Glyph="&#xe872;" />
                </Button>
                <Border Background="{ThemeResource AppBorderBrush}" Width="1" Height="24" Margin="2,0" VerticalAlignment="Center" />
                <Button x:Name="SelClearBtn" Style="{StaticResource ToolButtonStyle}" ToolTipService.ToolTip="Clear selection (Esc)">
                    <FontIcon Glyph="&#xe5cd;" />
                </Button>
            </StackPanel>
        </Border>

        <!-- Find-text panel — floats at top-right of canvas, shown by Search button -->
        <Border x:Name="SearchPanel"
                Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Canvas.ZIndex="9"
                HorizontalAlignment="Right" VerticalAlignment="Top"
                Margin="0,14,14,0"
                Visibility="Collapsed"
                CornerRadius="14"
                Background="{ThemeResource AppToolbarBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1"
                Translation="0,0,28">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="4" Padding="10,6" VerticalAlignment="Center">
                <TextBox x:Name="SearchBox" PlaceholderText="Find text…" Width="200"
                         VerticalAlignment="Center" BorderThickness="1" CornerRadius="6" Padding="6,4" />
                <TextBlock x:Name="SearchCountLabel" VerticalAlignment="Center" MinWidth="64"
                           Foreground="{ThemeResource AppTextSecondaryBrush}" FontSize="12"
                           TextAlignment="Center" />
                <Button x:Name="SearchPrevBtn" Style="{StaticResource ToolButtonStyle}"
                        ToolTipService.ToolTip="Previous match" IsEnabled="False">
                    <FontIcon Glyph="&#xe5ce;" FontSize="12" />
                </Button>
                <Button x:Name="SearchNextBtn" Style="{StaticResource ToolButtonStyle}"
                        ToolTipService.ToolTip="Next match" IsEnabled="False">
                    <FontIcon Glyph="&#xe5cf;" FontSize="12" />
                </Button>
                <Button x:Name="SearchCloseBtn" Style="{StaticResource ToolButtonStyle}"
                        ToolTipService.ToolTip="Close">
                    <FontIcon Glyph="&#xe5cd;" FontSize="12" />
                </Button>
            </StackPanel>
        </Border>

        <!-- Page sorter panel — slides in from the right edge of the canvas area -->
        <Border x:Name="PagePanel"
                Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                Canvas.ZIndex="5"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Width="152"
                Visibility="Collapsed"
                Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}"
                BorderThickness="1,0,0,0"
                Translation="0,0,24">
            <Border.Shadow>
                <ThemeShadow />
            </Border.Shadow>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Header: page indicator + Edit toggle -->
                <Border Grid.Row="0"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,8">
                    <Grid VerticalAlignment="Center">
                        <TextBlock x:Name="PageIndicator"
                                   Text="1 / 1"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                        <ToggleButton x:Name="PageEditModeBtn"
                                      HorizontalAlignment="Right"
                                      Padding="8,3"
                                      CornerRadius="6"
                                      Background="Transparent"
                                      BorderThickness="1"
                                      FontSize="12">
                            <TextBlock Text="Edit" FontSize="12" />
                        </ToggleButton>
                    </Grid>
                </Border>

                <!-- Selection action bar — shown when one or more cards are selected -->
                <Border x:Name="PageSelectionBar"
                        Grid.Row="1"
                        Visibility="Collapsed"
                        Background="{ThemeResource AppAccentSoftBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="10,6">
                    <Grid VerticalAlignment="Center">
                        <TextBlock x:Name="PageSelCount"
                                   Text="0 selected"
                                   VerticalAlignment="Center"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   Foreground="{ThemeResource AppAccentBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="2" HorizontalAlignment="Right">
                            <Button x:Name="PageSelDeleteBtn"
                                    Width="28" Height="28" Padding="0"
                                    CornerRadius="6"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Delete selected pages">
                                <FontIcon Glyph="&#xE872;" FontSize="18"
                                          Foreground="#E03A3A" />
                            </Button>
                            <Button x:Name="PageSelClearBtn"
                                    Width="28" Height="28" Padding="0"
                                    CornerRadius="6"
                                    Background="Transparent" BorderThickness="0"
                                    ToolTipService.ToolTip="Clear selection">
                                <FontIcon Glyph="&#xE5C9;" FontSize="18" />
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Scrollable thumbnail list -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="PageListPanel" Padding="8,10,8,10" Spacing="10" />
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Pinned bar (top, non-floating): back + history/file left, doc title center, view/actions right -->
        <Border x:Name="TopBar"
                Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3"
                Height="48"
                Background="Transparent"
                BorderBrush="{ThemeResource AppChromeHairlineBrush}"
                BorderThickness="0,0,0,1">
            <!-- Transparent so the window Mica reads through the bar (quieter than a
                 solid surface, no glass); a soft hairline separates it from the
                 canvas. Fixed 48dip so the compact button clusters share a
                 centerline with the Tall caption-button band. -->
            <Grid x:Name="TopBarGrid" Padding="8,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Window drag region. SetTitleBar turns this element's bounds into
                     non-client space (controls overlapping it lose input), so it only
                     covers the empty center column, not the button clusters. -->
                <Border x:Name="TopBarDragRegion" Grid.Column="1"
                        Background="Transparent" />

                <!-- Left: home · undo/redo · save/export -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center">
                    <Button x:Name="BackBtn" Style="{StaticResource TopBarButtonStyle}" ToolTipService.ToolTip="Home">
                        <FontIcon Glyph="&#xe88a;" FontSize="18" />
                    </Button>
                    <Border Background="{ThemeResource AppBorderBrush}" Width="1" Height="22"
                            VerticalAlignment="Center" />
                    <Border Style="{StaticResource TopBarGroupStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button x:Name="UndoBtn" Style="{StaticResource TopBarSegButtonStyle}"
                                    ToolTipService.ToolTip="Undo (Ctrl+Z)" IsEnabled="False">
                                <FontIcon Glyph="&#xe166;" FontSize="18" />
                            </Button>
                            <Border Style="{StaticResource TopBarSegDividerStyle}" />
                            <Button x:Name="RedoBtn" Style="{StaticResource TopBarSegButtonStyle}"
                                    ToolTipService.ToolTip="Redo (Ctrl+Y)" IsEnabled="False">
                                <FontIcon Glyph="&#xe15a;" FontSize="18" />
                            </Button>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource TopBarGroupStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button x:Name="SaveBtn" Style="{StaticResource TopBarSegButtonStyle}"
                                    ToolTipService.ToolTip="Save (Ctrl+S)">
                                <FontIcon Glyph="&#xe161;" FontSize="18" />
                            </Button>
                            <Border Style="{StaticResource TopBarSegDividerStyle}" />
                            <Button x:Name="ExportBtn" Style="{StaticResource TopBarSegButtonStyle}"
                                    ToolTipService.ToolTip="Export">
                                <FontIcon Glyph="&#xf3b2;" FontSize="18" />
                            </Button>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Center: document title + save state. Non-hit-testable so the
                     drag region underneath still moves the window. -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            IsHitTestVisible="False">
                    <TextBlock x:Name="TopBarTitle"
                               FontSize="14" FontWeight="SemiBold" MaxWidth="360"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                        <FontIcon x:Name="SaveStateCheck" Glyph="&#xe5ca;" FontSize="14"
                                  Foreground="{ThemeResource AppSuccessBrush}" VerticalAlignment="Center" />
                        <Ellipse x:Name="SaveStateDot" Width="6" Height="6"
                                 Fill="{ThemeResource AppAccentBrush}" Visibility="Collapsed"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="SaveStateText" Text="Saved"
                                   FontSize="12" Foreground="{ThemeResource AppSuccessBrush}"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </StackPanel>

                <!-- Right: view · insert menu · settings -->
                <StackPanel x:Name="ToolbarSecondary" Grid.Column="2" Orientation="Horizontal" Spacing="8"
                            Padding="0,0,4,0" VerticalAlignment="Center">
                    <!-- Fixed slot left of the page sorter (user request); not part of
                         the reorderable action slots, though the settings hide toggle
                         still applies. -->
                    <Button x:Name="ScreenshotBtn" Style="{StaticResource TopBarButtonStyle}" ToolTipService.ToolTip="Take screenshot">
                        <FontIcon Glyph="&#xe3b0;" FontSize="18" />
                    </Button>
                    <Border Style="{StaticResource TopBarGroupStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="0">
                            <Button x:Name="PagePanelBtn" Style="{StaticResource TopBarSegButtonStyle}" ToolTipService.ToolTip="Page sorter">
                                <FontIcon Glyph="&#xe8ef;" FontSize="18" />
                            </Button>
                            <Border Style="{StaticResource TopBarSegDividerStyle}" />
                            <Button x:Name="SearchBtn" Style="{StaticResource TopBarSegButtonStyle}" ToolTipService.ToolTip="Find text (Ctrl+F)">
                                <FontIcon Glyph="&#xe8b6;" FontSize="18" />
                            </Button>
                        </StackPanel>
                    </Border>
                    <!-- Invisible anchor: ApplyToolbarOrder re-inserts the reorderable
                         action slots (Insert menu) right after it. -->
                    <Border x:Name="TopSep1" Width="0" Visibility="Collapsed" />
                    <Border x:Name="AddMenuShell" Style="{StaticResource TopBarGroupStyle}">
                        <Button x:Name="AddMenuBtn" Style="{StaticResource TopBarAddButtonStyle}"
                                Width="Auto" ToolTipService.ToolTip="Insert">
                            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xe145;" FontSize="16" />
                                <TextBlock Text="Add" FontSize="13"
                                           FontFamily="{ThemeResource ContentControlThemeFontFamily}"
                                           VerticalAlignment="Center" />
                                <FontIcon Glyph="&#xe5cf;" FontSize="11" />
                            </StackPanel>
                            <Button.Flyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem x:Name="AddPageBtn" Text="Add blank page">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xe145;" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutItem x:Name="AddPdfPagesBtn" Text="Add pages from a PDF">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xe415;" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem x:Name="TemplateBtn" Text="Page template">
                                        <MenuFlyoutItem.Icon><FontIcon Glyph="&#xf79d;" /></MenuFlyoutItem.Icon>
                                    </MenuFlyoutItem>
                                </MenuFlyout>
                            </Button.Flyout>
                        </Button>
                    </Border>
                    <Border Background="{ThemeResource AppBorderBrush}" Width="1" Height="22"
                            VerticalAlignment="Center" />
                    <Button x:Name="SettingsBtn" Style="{StaticResource TopBarButtonStyle}" ToolTipService.ToolTip="Settings">
                        <FontIcon Glyph="&#xe8b8;" FontSize="18" />
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar — matches the top bar's quiet Mica chrome. -->
        <Border Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="3"
                Background="Transparent"
                BorderBrush="{ThemeResource AppChromeHairlineBrush}" BorderThickness="0,1,0,0">
            <Grid Padding="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="12" />
                <StackPanel x:Name="ZoomPanel" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                    <TextBlock Text="Zoom" Style="{StaticResource MutedStyle}" VerticalAlignment="Center" />
                    <Slider x:Name="ZoomSlider" Width="160" Minimum="25" Maximum="400" Value="100" />
                    <TextBlock x:Name="ZoomLabel" Text="100%" Style="{StaticResource MutedStyle}" VerticalAlignment="Center" Width="44" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Shown while a document opens on a background thread; the transparent
             grid also blocks input until the document is bound. -->
        <Grid x:Name="LoadingOverlay"
              Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="3"
              Canvas.ZIndex="20" Background="Transparent" Visibility="Collapsed">
            <ProgressRing x:Name="LoadingRing" Width="44" Height="44" IsActive="False" />
        </Grid>

        <!-- Save progress — a custom card while a .pdf is flattened + written.
             Non-hit-testable so the user can still scroll/zoom the document behind
             it; editing is blocked separately (canvas EditingSuspended + disabled
             toolbars) so the document can't be mutated mid-save. -->
        <Grid x:Name="SaveOverlay"
              Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="3"
              Canvas.ZIndex="30" Background="Transparent" IsHitTestVisible="False"
              Visibility="Collapsed">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    MinWidth="280" CornerRadius="16" Padding="26,22"
                    Background="{ThemeResource AppToolbarBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                    Translation="0,0,32">
                <Border.Shadow><ThemeShadow /></Border.Shadow>
                <StackPanel Spacing="14">
                    <TextBlock x:Name="SaveOverlayText" Text="Saving…"
                               FontSize="15" FontWeight="SemiBold" HorizontalAlignment="Center"
                               Foreground="{ThemeResource AppTextPrimaryBrush}" />
                    <ProgressBar x:Name="SaveProgressBar" Width="232" Minimum="0" Maximum="1" Value="0" />
                    <TextBlock x:Name="SaveOverlaySub" Text="" FontSize="12" HorizontalAlignment="Center"
                               Foreground="{ThemeResource AppTextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- Custom auto-dismissing toast (replaces the modal "Saved" dialog). -->
        <Border x:Name="ToastHost"
                Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="3"
                Canvas.ZIndex="40" HorizontalAlignment="Center" VerticalAlignment="Bottom"
                Margin="0,0,0,48" Visibility="Collapsed" IsHitTestVisible="False"
                CornerRadius="20" Padding="16,10"
                Background="{ThemeResource AppToolbarBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                Translation="0,0,32">
            <Border.Shadow><ThemeShadow /></Border.Shadow>
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <FontIcon x:Name="ToastIcon" Glyph="&#xe5ca;" FontSize="16"
                          Foreground="{ThemeResource AppSuccessBrush}" />
                <TextBlock x:Name="ToastText" Text="Saved" FontSize="13" VerticalAlignment="Center"
                           Foreground="{ThemeResource AppTextPrimaryBrush}" />
            </StackPanel>
        </Border>

        <!-- In-app screenshot region selector. Hit-testable so it intercepts all
             pointer input while active; drag a rectangle over the notes, then pick
             Copy / Insert / Save. The capture is re-rendered from the document, not
             grabbed from screen pixels, so it stays crisp. -->
        <Grid x:Name="ScreenshotOverlay"
              Grid.Row="0" Grid.RowSpan="4" Grid.Column="0" Grid.ColumnSpan="3"
              Canvas.ZIndex="45" Background="#01000000" Visibility="Collapsed"
              IsTabStop="True">
            <Canvas x:Name="ScreenshotCanvas">
                <!-- Four dim panels masking everything outside the selection. -->
                <Rectangle x:Name="MaskTop"    Fill="#59000000" IsHitTestVisible="False"/>
                <Rectangle x:Name="MaskBottom" Fill="#59000000" IsHitTestVisible="False"/>
                <Rectangle x:Name="MaskLeft"   Fill="#59000000" IsHitTestVisible="False"/>
                <Rectangle x:Name="MaskRight"  Fill="#59000000" IsHitTestVisible="False"/>
                <!-- Selection outline. -->
                <Border x:Name="ScreenshotRect" Visibility="Collapsed" IsHitTestVisible="False"
                        BorderBrush="{ThemeResource AppAccentBrush}" BorderThickness="2"
                        CornerRadius="2"/>
                <!-- Action bar, shown after the drag ends. -->
                <Border x:Name="ScreenshotActions" Visibility="Collapsed"
                        CornerRadius="12" Padding="6"
                        Background="{ThemeResource AppToolbarBrush}"
                        BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1"
                        Translation="0,0,32">
                    <Border.Shadow><ThemeShadow/></Border.Shadow>
                    <StackPanel Orientation="Horizontal" Spacing="2">
                        <Button x:Name="ShotCopyBtn" Style="{StaticResource ShotActionButtonStyle}"
                                ToolTipService.ToolTip="Copy to clipboard">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xe14d;" FontSize="16"/>
                                <TextBlock Text="Copy" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ShotInsertBtn" Style="{StaticResource ShotActionButtonStyle}"
                                ToolTipService.ToolTip="Insert into this note">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xe439;" FontSize="16"/>
                                <TextBlock Text="Insert" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="ShotSaveBtn" Style="{StaticResource ShotActionButtonStyle}"
                                ToolTipService.ToolTip="Save as PNG">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <FontIcon Glyph="&#xe161;" FontSize="16"/>
                                <TextBlock Text="Save" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Border Width="1" Margin="4,4" Background="{ThemeResource AppBorderBrush}"/>
                        <Button x:Name="ShotCancelBtn" Style="{StaticResource ShotActionButtonStyle}"
                                ToolTipService.ToolTip="Cancel (Esc)">
                            <FontIcon Glyph="&#xe5cd;" FontSize="16"/>
                        </Button>
                    </StackPanel>
                </Border>
            </Canvas>
            <!-- Hint pill. -->
            <Border VerticalAlignment="Top" HorizontalAlignment="Center"
                    Margin="0,72,0,0" CornerRadius="16" Padding="14,8" IsHitTestVisible="False"
                    Background="{ThemeResource AppToolbarBrush}"
                    BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="1">
                <TextBlock Text="Drag to capture a region  ·  Esc to cancel" FontSize="13"
                           Foreground="{ThemeResource AppTextPrimaryBrush}"/>
            </Border>
        </Grid>
    </Grid>
</Page>
