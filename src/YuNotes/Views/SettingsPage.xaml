<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="YuNotes.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource AppBackgroundBrush}">

    <Page.Resources>
        <DataTemplate x:Key="ToolItemTemplate">
            <Grid ColumnSpacing="12" Padding="0,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <FontIcon Grid.Column="0" Glyph="{Binding Glyph}" FontSize="18"
                          FontFamily="{StaticResource MaterialIconsFamily}"
                          VerticalAlignment="Center" HorizontalAlignment="Center"
                          Foreground="{ThemeResource AppTextPrimaryBrush}"/>
                <TextBlock Grid.Column="1" Text="{Binding Label}"
                           VerticalAlignment="Center"/>
                <CheckBox Grid.Column="2" IsChecked="{Binding IsVisible, Mode=TwoWay}"
                          VerticalAlignment="Center" Margin="0"/>
            </Grid>
        </DataTemplate>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="{ThemeResource AppSurfaceBrush}"
                BorderBrush="{ThemeResource AppBorderBrush}" BorderThickness="0,0,0,1">
            <Grid Padding="12,0" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" HorizontalAlignment="Left">
                    <Button x:Name="BackBtn" Style="{StaticResource ToolButtonStyle}" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xe5c4;" />
                    </Button>
                    <TextBlock Text="Settings" Style="{StaticResource H2Style}" VerticalAlignment="Center" />
                </StackPanel>
                <Button x:Name="SaveBtn" Content="Save" Padding="22,8" CornerRadius="10"
                        Background="{ThemeResource AppAccentBrush}" Foreground="White" BorderThickness="0"
                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer x:Name="RootScroller" Grid.Row="1" Padding="32,20,32,40">
            <StackPanel Spacing="20" MaxWidth="900" HorizontalAlignment="Center">

                <!-- ─── Preset colors ──────────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Preset colors" Style="{StaticResource H2Style}" />
                        <TextBlock Text="Colors shown in the toolbar flyout per tool. Add as many as you like."
                                   Style="{StaticResource MutedStyle}" />
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <RadioButton x:Name="ColorToolPen" Content="Pen" IsChecked="True" GroupName="ColorTool"/>
                            <RadioButton x:Name="ColorToolHighlighter" Content="Highlighter" GroupName="ColorTool"/>
                        </StackPanel>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Auto" VerticalScrollMode="Disabled">
                            <StackPanel x:Name="ColorsPanel" Orientation="Horizontal" Spacing="8" Padding="2"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>

                <!-- ─── Stylus & Pen Input ────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Stylus &amp; Pen Input" Style="{StaticResource H2Style}" />

                        <!-- 1) Pressure sensitivity -->
                        <StackPanel Spacing="8">
                            <CheckBox x:Name="PressureEnabledBox" Content="Enable pressure sensitivity" />
                            <Grid ColumnSpacing="12" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Text="Minimum pressure" VerticalAlignment="Center"/>
                                <Slider x:Name="MinPressureSlider" Grid.Column="1" Minimum="0" Maximum="0.5" StepFrequency="0.01"/>
                                <TextBlock x:Name="MinPressureLabel" Grid.Column="2" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="1" Text="Pressure multiplier" VerticalAlignment="Center"/>
                                <Slider x:Name="PressureMultSlider" Grid.Row="1" Grid.Column="1" Minimum="0.25" Maximum="3.0" StepFrequency="0.05"/>
                                <TextBlock x:Name="PressureMultLabel" Grid.Row="1" Grid.Column="2" VerticalAlignment="Center"/>
                            </Grid>
                            <TextBlock Text="If your stylus or OS doesn't expose pressure, these settings have no effect."
                                       Style="{StaticResource MutedStyle}" TextWrapping="Wrap"/>

                            <!-- Pressure test sandbox -->
                            <StackPanel Spacing="6">
                                <Grid>
                                    <TextBlock Text="Test draw — each sample is a circle sized to the pressure value."
                                               Style="{StaticResource MutedStyle}" />
                                    <Button x:Name="PressureClearBtn" Content="Clear"
                                            HorizontalAlignment="Right" Padding="10,4" CornerRadius="8"/>
                                </Grid>
                                <Border x:Name="PressureSandbox"
                                        Background="{ThemeResource AppSurfaceVariantBrush}"
                                        BorderBrush="{ThemeResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="10"
                                        Height="180"
                                        IsHitTestVisible="True">
                                    <Grid>
                                        <Canvas x:Name="PressureCanvas" IsHitTestVisible="False"/>
                                        <TextBlock x:Name="PressureHint" Text="Draw here with your pen to preview pressure."
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{ThemeResource AppTextSecondaryBrush}"
                                                   IsHitTestVisible="False" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border Background="{ThemeResource AppBorderBrush}" Height="1" Margin="0,2"/>

                        <!-- 3) Stylus buttons & eraser tip -->
                        <StackPanel Spacing="8">
                            <TextBlock Text="Stylus buttons &amp; eraser" FontWeight="SemiBold"/>
                            <Grid ColumnSpacing="12" RowSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220"/>
                                    <ColumnDefinition Width="240"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Button 1 (barrel)" VerticalAlignment="Center"/>
                                <ComboBox x:Name="BarrelCombo" Grid.Column="1" Width="220"/>
                            </Grid>

                            <TextBlock Text="Remappings are momentary: while a button is held the tool switches; the moment it's released, the previous tool returns. The eraser tip always activates the eraser using the current toolbar settings."
                                       Style="{StaticResource MutedStyle}" TextWrapping="Wrap"/>
                        </StackPanel>

                        <Border Background="{ThemeResource AppBorderBrush}" Height="1" Margin="0,2"/>

                        <!-- 4) Shape recognition -->
                        <ToggleSwitch x:Name="HoldToSnapToggle"
                                      Header="Hold-to-snap shape recognition"
                                      OnContent="On" OffContent="Off" />
                        <TextBlock Text="Draw a shape with the pen, then hold still for ~750 ms to snap it to a perfect line, ellipse, or rectangle. After snapping you can drag to adjust the shape before lifting the pen."
                                   Style="{StaticResource MutedStyle}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- ─── Palm rejection ──────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Palm rejection" Style="{StaticResource H2Style}" />
                        <ToggleSwitch x:Name="PalmToggle" Header="Enabled" />
                        <ToggleSwitch x:Name="IgnoreTouchToggle" Header="Ignore touch while pen is active" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBlock Text="Grace period (ms)" VerticalAlignment="Center" Width="200"/>
                            <NumberBox x:Name="GraceBox" Minimum="0" Maximum="3000" SpinButtonPlacementMode="Inline" Value="500"/>
                        </StackPanel>
                    </StackPanel>
                </Border>


                <!-- ─── Default widths ──────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Defaults" Style="{StaticResource H2Style}" />
                        <Grid ColumnSpacing="10" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Default pen width" VerticalAlignment="Center"/>
                            <NumberBox x:Name="PenWidthBox" Grid.Column="1" Minimum="1" Maximum="40" Value="2.5"/>
                            <TextBlock Grid.Row="1" Text="Default highlighter width" VerticalAlignment="Center"/>
                            <NumberBox x:Name="HighWidthBox" Grid.Row="1" Grid.Column="1" Minimum="2" Maximum="60" Value="18"/>
                            <TextBlock Grid.Row="2" Text="Default eraser width" VerticalAlignment="Center"/>
                            <NumberBox x:Name="EraserWidthBox" Grid.Row="2" Grid.Column="1" Minimum="2" Maximum="80" Value="20"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- ─── Layout ─────────────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Layout" Style="{StaticResource H2Style}" />
                        <Grid ColumnSpacing="10" RowSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="200"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/><RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="Toolbar position" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ToolbarPositionCombo" Grid.Column="1" Width="200">
                                <ComboBoxItem Content="Top" />
                                <ComboBoxItem Content="Bottom" />
                                <ComboBoxItem Content="Left" />
                                <ComboBoxItem Content="Right" />
                            </ComboBox>
                            <TextBlock Grid.Row="1" Text="Toolbar size" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ToolbarSizeCombo" Grid.Row="1" Grid.Column="1" Width="200">
                                <ComboBoxItem Content="Compact" />
                                <ComboBoxItem Content="Small" />
                                <ComboBoxItem Content="Normal" />
                                <ComboBoxItem Content="Large" />
                            </ComboBox>
                        </Grid>
                        <CheckBox x:Name="HideZoomBarBox" Content="Hide zoom bar" />
                        <CheckBox x:Name="SeamlessPagesBox" Content="Seamless pages (no gap between pages)" />
                    </StackPanel>
                </Border>

                <!-- ─── Toolbar ────────────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="14">
                        <TextBlock Text="Toolbar" Style="{StaticResource H2Style}" />
                        <TextBlock Text="Drag rows to reorder tools. Check the box to show a tool; uncheck to hide it. Hidden tools remain reachable via keyboard shortcuts and stylus buttons."
                                   Style="{StaticResource MutedStyle}" TextWrapping="Wrap" />

                        <TextBlock Text="Drawing tools" FontWeight="SemiBold" />
                        <ListView x:Name="DrawingToolsList"
                                  CanReorderItems="True" AllowDrop="True" CanDragItems="True"
                                  SelectionMode="None"
                                  ItemTemplate="{StaticResource ToolItemTemplate}"
                                  BorderThickness="1"
                                  BorderBrush="{ThemeResource AppBorderBrush}"
                                  CornerRadius="8">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="8,2"/>
                                    <Setter Property="MinHeight" Value="44"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <TextBlock Text="Action buttons" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        <TextBlock Text="These appear in the top title bar. Drag to change their order."
                                   Style="{StaticResource MutedStyle}" />
                        <ListView x:Name="ActionToolsList"
                                  CanReorderItems="True" AllowDrop="True" CanDragItems="True"
                                  SelectionMode="None"
                                  ItemTemplate="{StaticResource ToolItemTemplate}"
                                  BorderThickness="1"
                                  BorderBrush="{ThemeResource AppBorderBrush}"
                                  CornerRadius="8">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="Padding" Value="8,2"/>
                                    <Setter Property="MinHeight" Value="44"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>

                        <CheckBox x:Name="ToolVisExport" Content="Export (shown in title bar, fixed position)" />
                    </StackPanel>
                </Border>

                <!-- ─── Storage ─────────────────────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Storage" Style="{StaticResource H2Style}" />
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <TextBox x:Name="FolderBox" Width="500" IsReadOnly="True" />
                            <Button x:Name="PickFolderBtn" Content="Choose..." />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ─── Input Devices Diagnostics ─────────────────────────────── -->
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Input Devices Diagnostics" Style="{StaticResource H2Style}" />
                        <TextBlock Text="Try out your devices in the area below. Indicators light up as the app receives events."
                                   Style="{StaticResource MutedStyle}" TextWrapping="Wrap" />
                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="280"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Indicator chips -->
                            <StackPanel Spacing="12">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="Mouse" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border x:Name="IndMouseInUse" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="In use"/></Border>
                                        <Border x:Name="IndMouseL" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="Left"/></Border>
                                        <Border x:Name="IndMouseM" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="Middle"/></Border>
                                        <Border x:Name="IndMouseR" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="Right"/></Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Stylus" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border x:Name="IndPenHover" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="Hover"/></Border>
                                        <Border x:Name="IndPenTip" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="Tip"/></Border>
                                        <Border x:Name="IndPenB1" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="Button 1"/></Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Eraser" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Border x:Name="IndEraserHover" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="Hover"/></Border>
                                        <Border x:Name="IndEraserTip" Style="{StaticResource CardStyle}" Padding="8,4"><TextBlock Text="Tip"/></Border>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Touch" FontWeight="SemiBold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <Ellipse x:Name="Touch1" Width="14" Height="14" Fill="{ThemeResource AppBorderBrush}"/>
                                        <Ellipse x:Name="Touch2" Width="14" Height="14" Fill="{ThemeResource AppBorderBrush}"/>
                                        <Ellipse x:Name="Touch3" Width="14" Height="14" Fill="{ThemeResource AppBorderBrush}"/>
                                        <Ellipse x:Name="Touch4" Width="14" Height="14" Fill="{ThemeResource AppBorderBrush}"/>
                                        <Ellipse x:Name="Touch5" Width="14" Height="14" Fill="{ThemeResource AppBorderBrush}"/>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Spacing="4">
                                    <TextBlock Text="Last device used" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="LastDeviceText" Text="(none yet)" Style="{StaticResource MutedStyle}"/>
                                </StackPanel>
                            </StackPanel>

                            <!-- Sandbox -->
                            <Border Grid.Column="1"
                                    x:Name="Sandbox"
                                    Background="{ThemeResource AppSurfaceVariantBrush}"
                                    BorderBrush="{ThemeResource AppBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Height="320"
                                    IsHitTestVisible="True">
                                <TextBlock Text="Tap, click, or draw here." Foreground="{ThemeResource AppTextSecondaryBrush}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                            </Border>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <Button x:Name="ShowLogsBtn" Content="Show logs"/>
                            <Button x:Name="ExportDebugBtn" Content="Export debug info"/>
                            <Button x:Name="CrashLogBtn" Content="View crash log"/>
                        </StackPanel>
                        <TextBlock Text="To clear the logs, simply close and reopen the settings page."
                                   Style="{StaticResource MutedStyle}"/>
                        <CheckBox x:Name="EmulateTipBox" Content="Emulate stylus tip contact on button press"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
