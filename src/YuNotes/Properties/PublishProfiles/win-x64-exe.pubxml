<?xml version="1.0" encoding="utf-8"?>
<!--
  Unpackaged, self-contained, SINGLE-FILE .exe publish profile.

  This is an ALTERNATIVE to the MSIX/Store build (packaging\build.ps1 /
  build-store.ps1). It produces one standalone YuNotes.exe that carries
  everything inside it:
    * WindowsPackageType=None            -> loose exe, no MSIX identity/install
    * SelfContained=true                 -> the .NET 8 runtime is bundled
    * WindowsAppSDKSelfContained=true    -> the Windows App SDK runtime is bundled
    * PublishSingleFile + IncludeAllContentForSelfExtract
                                         -> every managed DLL, native DLL and
                                            resources.pri is packed INTO the exe
                                            and self-extracts to a temp folder on
                                            first launch.

  The csproj itself stays packaged (MSIX) by default so the Store build is
  unaffected; these properties only apply when this profile is used.

  Build it with:  packaging\publish-exe.ps1   (or "Build Standalone EXE.bat")
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>x64</Platform>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishProtocol>FileSystem</PublishProtocol>

    <!-- Unpackaged loose exe (overrides the csproj's packaged default). -->
    <WindowsPackageType>None</WindowsPackageType>

    <!-- Bundle the .NET runtime and the Windows App SDK runtime so the exe
         needs nothing preinstalled on the target machine. -->
    <SelfContained>true</SelfContained>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>

    <!-- Fold everything into a single self-extracting exe. -->
    <PublishSingleFile>true</PublishSingleFile>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
    <IncludeAllContentForSelfExtract>true</IncludeAllContentForSelfExtract>
    <EnableCompressionInSingleFile>true</EnableCompressionInSingleFile>

    <!-- Trimming/R2R break WinUI XAML reflection and offer little here. -->
    <PublishTrimmed>false</PublishTrimmed>
    <PublishReadyToRun>false</PublishReadyToRun>

    <!-- Never emit an MSIX for this profile. -->
    <GenerateAppxPackageOnBuild>false</GenerateAppxPackageOnBuild>
    <AppxPackageSigningEnabled>false</AppxPackageSigningEnabled>
  </PropertyGroup>
</Project>
