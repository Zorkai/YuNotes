<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- wght=200 static instance — regenerate from the Google variable font with
         fonttools varLib.instancer if a different weight is ever needed. -->
    <FontFamily x:Key="MaterialIconsFamily">ms-appx:///Assets/MaterialSymbolsOutlinedLight.ttf#Material Symbols Outlined</FontFamily>

    <!-- Display optical size of Segoe UI Variable — tuned for large text
         (tighter spacing, crisper strokes). Used by H1Style; body text keeps
         the default Text optical size. -->
    <FontFamily x:Key="DisplayFontFamily">Segoe UI Variable Display,Segoe UI</FontFamily>

    <!-- ── Type scale ───────────────────────────────────────────────────────
         One ladder of font sizes used across the whole app. Prefer these (and the
         H1/H2/Muted styles below) over ad-hoc FontSize values so text stays consistent. -->
    <x:Double x:Key="FontSizeDisplay">28</x:Double>     <!-- page title -->
    <x:Double x:Key="FontSizeHeading">18</x:Double>     <!-- section header -->
    <x:Double x:Key="FontSizeSubheading">16</x:Double>  <!-- content / top-bar title -->
    <x:Double x:Key="FontSizeBody">14</x:Double>        <!-- default body, card title, row icons -->
    <x:Double x:Key="FontSizeSecondary">13</x:Double>   <!-- labels, muted text, sidebar -->
    <x:Double x:Key="FontSizeCaption">12</x:Double>     <!-- small UI labels -->
    <x:Double x:Key="FontSizeMicro">11</x:Double>       <!-- badges, timestamps -->

    <!-- Inline icon glyph size, paired with body/secondary text in rows. -->
    <x:Double x:Key="IconSizeRow">14</x:Double>

    <Style TargetType="FontIcon">
        <Setter Property="FontFamily" Value="{StaticResource MaterialIconsFamily}" />
    </Style>

    <!-- Flat tool button matching the toggle style: no per-button background,
         white icon, subtle hover/press overlay. Used in the top bar and other
         non-toggle tool slots. -->
    <Style x:Key="ToolButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="FontFamily" Value="{StaticResource MaterialIconsFamily}" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <!-- RenderTransformOrigin (relative) rather than CenterPoint:
                         the editor resizes these buttons at runtime, so the squish
                         must stay centered at any size. -->
                    <Grid x:Name="RootGrid" Background="Transparent"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform />
                        </Grid.RenderTransform>
                        <Border x:Name="HoverLayer"
                                Background="{ThemeResource AppSurfaceVariantBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0" />
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <!-- Eases the press squish back out instead of snapping. -->
                                    <VisualTransition From="Pressed" GeneratedDuration="0:0:0.08" />
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.5" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.92" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.92" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Left accent bar style: no per-button background, muted icon when inactive,
         accent-colored icon plus a small left vertical bar when checked. -->
    <Style x:Key="ToolToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
        <Setter Property="CornerRadius" Value="22" />
        <Setter Property="FontFamily" Value="{StaticResource MaterialIconsFamily}" />
        <Setter Property="FontSize" Value="24" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <!-- RenderTransformOrigin (relative) rather than CenterPoint:
                         the editor resizes these buttons at runtime, so the squish
                         must stay centered at any size. -->
                    <Grid x:Name="RootGrid" Background="Transparent"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform />
                        </Grid.RenderTransform>
                        <Border x:Name="HoverLayer"
                                Background="{ThemeResource AppSurfaceVariantBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0" />
                        <!-- Hidden at ScaleY 0 and grows in vertically on check
                             (NavigationView-style indicator). The bar is a fixed
                             3x20 — code only resizes the buttons — so the absolute
                             CenterPoint is safe here. -->
                        <Rectangle x:Name="AccentBar"
                                   Width="3" Height="20"
                                   RadiusX="2" RadiusY="2"
                                   HorizontalAlignment="Left" VerticalAlignment="Center"
                                   Fill="{ThemeResource AppAccentBrush}"
                                   Margin="2,0,0,0"
                                   CenterPoint="1.5,10,0"
                                   Scale="1,0,1">
                            <Rectangle.ScaleTransition>
                                <Vector3Transition Duration="0:0:0.15" />
                            </Rectangle.ScaleTransition>
                        </Rectangle>
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <!-- Eases the press squish back out instead of snapping. -->
                                    <VisualTransition From="Pressed" GeneratedDuration="0:0:0.08" />
                                    <VisualTransition From="CheckedPressed" GeneratedDuration="0:0:0.08" />
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.5" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.92" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.92" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <VisualState.Setters>
                                        <Setter Target="AccentBar.Scale" Value="1,1,1" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AppAccentBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="AccentBar.Scale" Value="1,1,1" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.35" Duration="0:0:0.1" />
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AppAccentBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <VisualState.Setters>
                                        <Setter Target="AccentBar.Scale" Value="1,1,1" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.55" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.92" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.92" Duration="0:0:0.1" />
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AppAccentBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedDisabled">
                                    <VisualState.Setters>
                                        <Setter Target="AccentBar.Scale" Value="1,1,1" />
                                    </VisualState.Setters>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Chevron sub-button (Pen/Eraser/Shape/Select flyout triggers). The default
         WinUI Button hover/press background was painting a gray rectangle on top of
         the parent tool icon at small toolbar sizes — this template keeps it muted. -->
    <Style x:Key="ToolChevronButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Background="Transparent">
                        <Border x:Name="ChevronHover"
                                Background="{ThemeResource AppSurfaceVariantBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0" />
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ChevronHover"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.35" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ChevronHover"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.55" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- GridViewItem style for note cards: shadow elevation + implicit scale on hover/press.
         Uses UIElement.Scale + Vector3Transition for the spring effect (no Storyboard needed,
         avoiding the WAS 1.5 XAML compiler limitation with non-UIElement Storyboard targets). -->
    <Style x:Key="NoteCardContainerStyle" TargetType="GridViewItem">
        <Setter Property="Margin" Value="0,0,12,12" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="VerticalContentAlignment" Value="Stretch" />
        <Setter Property="UseSystemFocusVisuals" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GridViewItem">
                    <Grid x:Name="CardGrid"
                          CornerRadius="14"
                          CenterPoint="83,108,0"
                          Translation="0,0,6">
                        <Grid.Shadow>
                            <ThemeShadow />
                        </Grid.Shadow>
                        <Grid.ScaleTransition>
                            <Vector3Transition Duration="0:0:0.2" />
                        </Grid.ScaleTransition>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="HoverBorder.Opacity" Value="1" />
                                        <Setter Target="CardGrid.Scale" Value="1.035,1.035,1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="HoverBorder.Opacity" Value="1" />
                                        <Setter Target="CardGrid.Scale" Value="0.96,0.96,1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Selected">
                                    <VisualState.Setters>
                                        <Setter Target="SelTint.Opacity" Value="0.22" />
                                        <Setter Target="SelBorder.Opacity" Value="1" />
                                        <Setter Target="CheckBadge.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PointerOverSelected">
                                    <VisualState.Setters>
                                        <Setter Target="SelTint.Opacity" Value="0.22" />
                                        <Setter Target="SelBorder.Opacity" Value="1" />
                                        <Setter Target="CheckBadge.Opacity" Value="1" />
                                        <Setter Target="CardGrid.Scale" Value="1.035,1.035,1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="PressedSelected">
                                    <VisualState.Setters>
                                        <Setter Target="SelTint.Opacity" Value="0.22" />
                                        <Setter Target="SelBorder.Opacity" Value="1" />
                                        <Setter Target="CheckBadge.Opacity" Value="1" />
                                        <Setter Target="CardGrid.Scale" Value="0.96,0.96,1" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="SelectedUnfocused">
                                    <VisualState.Setters>
                                        <Setter Target="SelTint.Opacity" Value="0.22" />
                                        <Setter Target="SelBorder.Opacity" Value="1" />
                                        <Setter Target="CheckBadge.Opacity" Value="1" />
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>

                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="Stretch"
                            VerticalAlignment="Stretch" />

                        <Border x:Name="HoverBorder"
                                CornerRadius="14"
                                BorderThickness="1"
                                BorderBrush="{ThemeResource AppAccentBrush}"
                                Opacity="0"
                                IsHitTestVisible="False" />

                        <Border x:Name="SelTint"
                                CornerRadius="14"
                                Background="{ThemeResource AppAccentSoftBrush}"
                                Opacity="0"
                                IsHitTestVisible="False" />
                        <Border x:Name="SelBorder"
                                CornerRadius="14"
                                BorderThickness="2.5"
                                BorderBrush="{ThemeResource AppAccentBrush}"
                                Opacity="0"
                                IsHitTestVisible="False" />

                        <Border x:Name="CheckBadge"
                                Width="28" Height="28"
                                CornerRadius="14"
                                Background="{ThemeResource AppAccentBrush}"
                                BorderBrush="{ThemeResource AppSurfaceBrush}"
                                BorderThickness="2"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Top"
                                Margin="0,8,8,0"
                                Opacity="0"
                                IsHitTestVisible="False">
                            <FontIcon Glyph="&#xE5CA;"
                                      FontSize="16"
                                      FontFamily="{StaticResource MaterialIconsFamily}"
                                      Foreground="White" />
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- App-wide menu presenter (applies to every MenuFlyout, including ones
         built in code). The glass fill/border comes from the lightweight
         resource overrides in Colors.xaml; the extra vertical padding keeps
         item hover rectangles clear of the 14px rounded corners. -->
    <Style TargetType="MenuFlyoutPresenter" BasedOn="{StaticResource DefaultMenuFlyoutPresenterStyle}">
        <Setter Property="Padding" Value="0,6,0,6" />
    </Style>

    <!-- Glass flyout presenter — pair with ShouldConstrainToRootBounds="True"
         on the Flyout itself: constrained popups live in the main XAML root,
         where in-app acrylic can sample (and blur) the app content beneath. -->
    <Style x:Key="GlassFlyoutPresenterStyle" TargetType="FlyoutPresenter" BasedOn="{StaticResource DefaultFlyoutPresenterStyle}">
        <Setter Property="Background" Value="{ThemeResource AppPopupAcrylicBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="12" />
    </Style>

    <!-- Color flyout: same glass look, but drops the inherited 96px
         FlyoutThemeMinWidth so a vertical (sidebar) swatch column hugs its
         36px width instead of floating in an over-wide box. The horizontal
         swatch row is already wider than the min, so this is a no-op there. -->
    <Style x:Key="ColorFlyoutPresenterStyle" TargetType="FlyoutPresenter" BasedOn="{StaticResource GlassFlyoutPresenterStyle}">
        <Setter Property="MinWidth" Value="0" />
    </Style>

    <!-- Segmented group for the top bar: a hairline-outlined shell that clips its
         buttons to a rounded rect, so a pair of square buttons + a 1px divider
         reads as one segmented control. Padding 0 → buttons sit flush to the
         border; 32px buttons + 1px top/bottom border = a 34px unit. -->
    <Style x:Key="TopBarGroupStyle" TargetType="Border">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- Square button that lives inside a TopBarGroupStyle segment: no corner
         radius of its own (the group border clips the outer corners). -->
    <Style x:Key="TopBarSegButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="0" />
    </Style>

    <!-- Standalone compact top-bar button (Home, screenshot, settings): a small
         rounded-rect rather than a big circle. -->
    <Style x:Key="TopBarButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
        <Setter Property="Width" Value="38" />
        <Setter Property="Height" Value="34" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>

    <!-- The "+ Add" pill: text + chevron, so it auto-sizes and uses the UI font
         (not the icon font) for the label. Sits inside a TopBarGroupStyle shell. -->
    <Style x:Key="TopBarAddButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
        <Setter Property="Width" Value="NaN" />
        <Setter Property="Height" Value="32" />
        <Setter Property="CornerRadius" Value="0" />
        <Setter Property="Padding" Value="10,0" />
        <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
    </Style>

    <!-- Auto-sizing labelled button for the screenshot action bar (Copy/Insert/Save). -->
    <Style x:Key="ShotActionButtonStyle" TargetType="Button" BasedOn="{StaticResource ToolButtonStyle}">
        <Setter Property="Width" Value="NaN" />
        <Setter Property="Height" Value="34" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="11,0" />
        <Setter Property="FontFamily" Value="{ThemeResource ContentControlThemeFontFamily}" />
    </Style>

    <!-- Divider bar between two segments inside a TopBarGroupStyle. -->
    <Style x:Key="TopBarSegDividerStyle" TargetType="Border">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
    </Style>

    <!-- Section label at the top of the tool flyouts ("Pen", "Eraser", …). -->
    <Style x:Key="FlyoutHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSecondary}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
        <Setter Property="Margin" Value="2,0,0,0" />
    </Style>

    <!-- Option card for the tool flyouts: icon + label, selected card gets a
         solid slab over the popup glass with accent content. Same press squish
         as the toolbar buttons. -->
    <Style x:Key="OptionCardStyle" TargetType="ToggleButton">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="12,10" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Grid x:Name="RootGrid" Background="Transparent"
                          RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform />
                        </Grid.RenderTransform>
                        <Border x:Name="HoverLayer"
                                Background="{ThemeResource AppSurfaceVariantBrush}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0" />
                        <Border x:Name="CardBg"
                                Background="{ThemeResource AppPopupCardBrush}"
                                BorderBrush="{ThemeResource AppBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0" />
                        <ContentPresenter x:Name="ContentPresenter"
                                          Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Padding="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Foreground="{TemplateBinding Foreground}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualStateGroup.Transitions>
                                    <VisualTransition From="Pressed" GeneratedDuration="0:0:0.08" />
                                    <VisualTransition From="CheckedPressed" GeneratedDuration="0:0:0.08" />
                                </VisualStateGroup.Transitions>
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.5" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.7" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.94" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.94" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Checked">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CardBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AppAccentBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CardBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AppAccentBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CardBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                         To="0.94" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="RootGrid"
                                                         Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                         To="0.94" Duration="0:0:0.1" />
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter"
                                                                       Storyboard.TargetProperty="Foreground">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource AppAccentBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedDisabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="CardBg"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="ContentPresenter"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Color swatch button. The default Button template swaps the background
         to a gray theme brush on hover, wiping out the swatch color — this one
         keeps the color and shows an accent ring instead. -->
    <Style x:Key="SwatchButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid Background="Transparent">
                        <Border x:Name="Fill"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{TemplateBinding CornerRadius}" />
                        <Border x:Name="HoverRing"
                                BorderBrush="{ThemeResource AppAccentBrush}"
                                BorderThickness="2"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Opacity="0" />
                        <ContentPresenter Content="{TemplateBinding Content}"
                                          ContentTemplate="{TemplateBinding ContentTemplate}"
                                          Foreground="{TemplateBinding Foreground}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverRing"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.1" />
                                        <DoubleAnimation Storyboard.TargetName="Fill"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.75" Duration="0:0:0.1" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="Disabled">
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Fill"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0.4" Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource AppBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="H1Style" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource DisplayFontFamily}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeDisplay}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
    </Style>
    <Style x:Key="H2Style" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeHeading}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextPrimaryBrush}" />
    </Style>
    <Style x:Key="MutedStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeSecondary}" />
        <Setter Property="Foreground" Value="{ThemeResource AppTextSecondaryBrush}" />
    </Style>
</ResourceDictionary>
