<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="YuNotes.Controls.ColorPickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!--
        Single-button color picker. The button shows the current color; clicking
        it opens a flyout with the preset swatches plus a "custom color" entry.
        Frees up a lot of horizontal toolbar real estate compared to showing all
        five swatches inline.
    -->
    <Button x:Name="CurrentColorBtn"
            Width="44" Height="44"
            CornerRadius="12"
            Padding="0"
            BorderThickness="2"
            BorderBrush="{ThemeResource AppBorderBrush}"
            ToolTipService.ToolTip="Color"
            VerticalAlignment="Center">
        <Button.Flyout>
            <Flyout x:Name="ColorFlyout" Placement="Bottom"
                    ShouldConstrainToRootBounds="True"
                    FlyoutPresenterStyle="{StaticResource ColorFlyoutPresenterStyle}">
                <!-- Constrained popup: keeps the flyout in the main XAML root so
                     the in-app acrylic presenter background can blur app content. -->
                <StackPanel x:Name="FlyoutPanel" Orientation="Horizontal" Spacing="8" />
            </Flyout>
        </Button.Flyout>
    </Button>
</UserControl>
