<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="YuNotes.Controls.WidthPickerControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{ThemeResource AppSurfaceVariantBrush}"
            BorderBrush="{ThemeResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="3"
            VerticalAlignment="Center">
        <StackPanel x:Name="Root" Orientation="Horizontal" Spacing="0" VerticalAlignment="Center" />
    </Border>
</UserControl>
